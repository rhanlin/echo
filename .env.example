# echo server configuration
#
# Copy to `.env` (loaded automatically by Bun) or export before launching.

# Port the HTTP + WebSocket server listens on.
SERVER_PORT=4000

# SQLite database file path. Use `:memory:` for ephemeral runs.
DB_PATH=./events.db

# CORS allow-list. `*` allows everything; otherwise comma-separated origins.
# Examples:
#   CORS_ORIGINS=*
#   CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ORIGINS=*

# Maximum events delivered in the initial WebSocket /stream snapshot.
WS_SNAPSHOT_LIMIT=300
